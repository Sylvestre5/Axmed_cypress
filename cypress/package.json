{
  "scripts": {
    "serve": "http-server .. -p 4173 -s",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:chrome": "cypress run --browser chrome",
    "cy:run:firefox": "cypress run --browser firefox",
    "cy:run:edge": "cypress run --browser edge",
    "test": "start-server-and-test serve http://localhost:4173 cy:run",
    "test:open": "start-server-and-test serve http://localhost:4173 cy:open --timeout 30000",
    "test:all-browsers": "start-server-and-test serve http://localhost:4173 \"cy:run:chrome && npm run cy:run:firefox && npm run cy:run:edge\""
  },
  "devDependencies": {
    "cypress": "^15.18.0",
    "http-server": "^14.1.1",
    "start-server-and-test": "^2.1.5",
    "typescript": "^5.5.4"
  }
}
